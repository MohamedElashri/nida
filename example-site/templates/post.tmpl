{{- define "post" -}}{{ template "base" . }}{{- end }}
{{- define "content" }}
  <article class="article">
    <p class="eyebrow">{{ formatDate .Page.Date }}</p>
    <h1>{{ .Page.Title }}</h1>
    <p class="lede">{{ .Page.Description }}</p>
    <div class="article-meta">
      {{ if .Page.Tags }}<p><strong>Tags:</strong> {{ join .Page.Tags ", " }}</p>{{ end }}
      {{ if .Page.Categories }}<p><strong>Categories:</strong> {{ join .Page.Categories ", " }}</p>{{ end }}
    </div>
    <div class="prose">{{ safeHTML .Page.BodyHTML }}</div>
  </article>
{{- end }}
