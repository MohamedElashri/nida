{{- define "base" -}}
<!doctype html>
<html lang="{{ default .Config.Language "en" }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ .Title }} | {{ .Config.Title }}</title>
  <meta name="description" content="{{ default .Page.Description .Config.Description }}">
  <link rel="stylesheet" href="/site.css">
</head>
<body>
  <div class="page-shell">
    <header class="site-header">
      <div class="brand-block">
        <a class="brand" href="{{ .HomeURL }}">{{ .Config.Title }}</a>
        <p class="tagline">{{ .Config.Description }}</p>
      </div>
      <nav class="site-nav" aria-label="Primary">
        <a href="/">Home</a>
        <a href="/posts/">Archive</a>
        <a href="/about/">About</a>
        <a href="/colophon/">Colophon</a>
      </nav>
    </header>
    <main class="content-shell">
      {{- template "content" . }}
    </main>
    <footer class="site-footer">
      <p>Published with Nida. Built for a calm writing workflow.</p>
    </footer>
  </div>
</body>
</html>
{{- end }}
